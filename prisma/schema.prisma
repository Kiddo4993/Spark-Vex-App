// SparkVEX Database Schema
// We threw this together to track everything from raw match scores to our Bayesian rating system.
// Trying to keep it as simple as possible while still supporting the deep scouting features.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Basic auth setup. We decided to keep it tied directly to the team, 
// so each team basically shares one login account for scouting.
model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  password  String
  teamId    String   @unique
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// The core profile for every robot. We use the official VEX team number (like 1234A) 
// everywhere because that's how we all actually talk about teams.
model Team {
  id                    String    @id @default(cuid())
  teamNumber            String    @unique
  generatedPassword     String?
  provinceState         String?
  country               String?
  drivetrainType        String?
  autonomousSide        String?
  autonReliabilityPct   Float?
  notes                 String?  @db.Text
  strategyTags          String[]

  user                  User?
  performanceHistory    PerformanceHistory[]
  teamMatchStats        TeamMatchStats[]
  calculatedRatingsAsUploader CalculatedRating[] @relation("RatingUploader")
  calculatedRatingsAsSubject CalculatedRating[] @relation("RatingSubject")
  scoutingDataAsScouter ScoutingData[] @relation("Scouter")
  scoutingDataAsSubject ScoutingData[] @relation("ScoutingSubject")
  uploadedMatches       Match[]      @relation("UploaderLocation")
  connectionsFrom       Connection[] @relation("ConnectionFrom")
  connectionsTo         Connection[] @relation("ConnectionTo")
  sharedNotesFrom       Note[]       @relation("NoteFrom")
  sharedNotesTo         Note[]       @relation("NoteTo")
  matchComments         MatchComment[]
  matchesAsRed1         Match[]      @relation("RedTeam1")
  matchesAsRed2         Match[]      @relation("RedTeam2")
  matchesAsRed3         Match[]      @relation("RedTeam3")
  matchesAsBlue1        Match[]      @relation("BlueTeam1")
  matchesAsBlue2        Match[]      @relation("BlueTeam2")
  matchesAsBlue3        Match[]      @relation("BlueTeam3")
  messagesSent          Message[]    @relation("MessageFrom")
  messagesReceived      Message[]    @relation("MessageTo")
  taskColumns           TaskColumn[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// Stores the raw results from competition matches. We feed this into the math models
// to get objective data instead of just relying on human scouters who might be biased.
model Match {
  id          String   @id @default(cuid())
  eventName   String
  date        DateTime
  redScore    Int
  blueScore   Int
  uploaderId  String
  uploader    Team     @relation("UploaderLocation", fields: [uploaderId], references: [id], onDelete: Cascade)

  redTeam1Id  String
  redTeam2Id  String
  redTeam3Id  String
  blueTeam1Id String
  blueTeam2Id String
  blueTeam3Id String
  redTeam1    Team     @relation("RedTeam1", fields: [redTeam1Id], references: [id])
  redTeam2    Team     @relation("RedTeam2", fields: [redTeam2Id], references: [id])
  redTeam3    Team     @relation("RedTeam3", fields: [redTeam3Id], references: [id])
  blueTeam1   Team     @relation("BlueTeam1", fields: [blueTeam1Id], references: [id])
  blueTeam2   Team     @relation("BlueTeam2", fields: [blueTeam2Id], references: [id])
  blueTeam3   Team     @relation("BlueTeam3", fields: [blueTeam3Id], references: [id])
  teamMatchStats TeamMatchStats[]
  comments    MatchComment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// The secret sauce for our Bayesian system. This breaks down exactly how much 
// a specific team contributed to their alliance's win or loss based on expected outcomes.
model TeamMatchStats {
  id          String   @id @default(cuid())
  matchId     String
  teamId      String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  alliance    String
  score       Int

  performanceBefore     Float
  performanceAfter      Float
  uncertaintyBefore     Float
  uncertaintyAfter      Float
  expectedOutcome       Float
  carryFactor           Float
  surpriseFactor        Float
  createdAt   DateTime @default(now())
  @@unique([matchId, teamId])
  @@index([teamId])
  @@index([matchId])
}

// Lets us graph out a team's progress over the season to see if their 
// bot is getting better over time, or if they peaked early.
model PerformanceHistory {
  id                String   @id @default(cuid())
  teamId            String
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  performanceRating Float
  uncertainty       Float
  matchId           String?
  createdAt         DateTime @default(now())
  @@index([teamId])
}

// These are the overarching ratings calculated for a team after running all their stats.
// We use this to rank teams in the alliance selection process.
model CalculatedRating {
  id                String   @id @default(cuid())
  uploaderId        String
  subjectTeamId     String
  uploader          Team     @relation("RatingUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  subjectTeam       Team     @relation("RatingSubject", fields: [subjectTeamId], references: [id], onDelete: Cascade)
  performanceRating Float    @default(100)
  ratingUncertainty Float    @default(50)
  matchCount        Int      @default(0)
  lastUpdated       DateTime @default(now())

  @@unique([uploaderId, subjectTeamId])
  @@index([uploaderId])
  @@index([subjectTeamId])
}

// The manual scouting stuff. Things you can't get from API data, like how good
// their driver actually is, or if their autonomous totally bricks sometimes.
model ScoutingData {
  id                String   @id @default(cuid())
  scouterId         String
  subjectTeamId     String
  scouter           Team     @relation("Scouter", fields: [scouterId], references: [id], onDelete: Cascade)
  subjectTeam       Team     @relation("ScoutingSubject", fields: [subjectTeamId], references: [id], onDelete: Cascade)
  autoStrength      Float?
  driverStrength    Float?
  notes             String?   @db.Text
  lastUpdated       DateTime @default(now())

  @@unique([scouterId, subjectTeamId])
  @@index([scouterId])
  @@index([subjectTeamId])
}

// Connect system so teams can link up on the app, kind of like adding friends.
// Super useful for organizing practice matches or building alliances early.
model Connection {
  id        String   @id @default(cuid())
  fromTeamId String
  toTeamId   String
  status    String
  fromTeam  Team     @relation("ConnectionFrom", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeam    Team     @relation("ConnectionTo", fields: [toTeamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([fromTeamId, toTeamId])
  @@index([toTeamId])
  @@index([fromTeamId])
}

// Shared notebook so teams in a connection can drop strategy intel 
// or let each other know what to watch out for against mutual opponents.
model Note {
  id        String   @id @default(cuid())
  fromTeamId String
  toTeamId   String
  type      String
  content   String   @db.Text
  fromTeam  Team     @relation("NoteFrom", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeam    Team     @relation("NoteTo", fields: [toTeamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([fromTeamId])
  @@index([toTeamId])
}

// Quick discussion board attached to a specific match, in case a referee made a bad call
// or someone wants to point out something crazy that happened.
model MatchComment {
  id        String   @id @default(cuid())
  matchId   String
  teamId    String
  content   String   @db.Text
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([matchId])
  @@index([teamId])
}

// Direct messaging between teams. Had to add this because Discord is too distracting
// during an actual event and we needed a place to coordinate.
model Message {
  id        String   @id @default(cuid())
  fromTeamId String
  toTeamId   String
  content   String   @db.Text
  read      Boolean  @default(false)
  fromTeam  Team     @relation("MessageFrom", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeam    Team     @relation("MessageTo", fields: [toTeamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([fromTeamId])
  @@index([toTeamId])
}

// A built-in Kanban board for project management. We kept forgetting who was building what
// on the robot, so we baked this right into the team dashboard.
model TaskColumn {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([teamId])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  priority    String       @default("medium")
  dueDate     DateTime?
  order       Int          @default(0)
  columnId    String
  column      TaskColumn   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignees   String[]
  tags        String[]
  subtasks    Subtask[]
  comments    TaskComment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@index([columnId])
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([taskId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  author    String
  content   String   @db.Text
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([taskId])
}

